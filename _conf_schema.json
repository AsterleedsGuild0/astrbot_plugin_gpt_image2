{
  "api_key": {
    "description": "API Key",
    "type": "string",
    "hint": "第三方 OpenAI 兼容 API Key",
    "obvious_hint": true
  },
  "base_url": {
    "description": "API Base URL",
    "type": "string",
    "default": "https://api.openai.com/v1",
    "hint": "例如 https://api.example.com/v1，不要以 images/generations 结尾"
  },
  "api_mode": {
    "description": "API 模式",
    "type": "string",
    "default": "images",
    "options": ["images", "responses"],
    "labels": ["Images API", "Responses API"]
  },
  "model": {
    "description": "Images API 模型",
    "type": "string",
    "default": "gpt-image-2"
  },
  "responses_model": {
    "description": "Responses API 模型",
    "type": "string",
    "default": "gpt-5.5"
  },
  "size": {
    "description": "图片尺寸",
    "type": "string",
    "default": "auto",
    "options": ["auto", "1024x1024", "1536x1024", "1024x1536"]
  },
  "quality": {
    "description": "图片质量",
    "type": "string",
    "default": "auto",
    "options": ["auto", "low", "medium", "high"]
  },
  "output_format": {
    "description": "输出格式",
    "type": "string",
    "default": "png",
    "options": ["png", "jpeg", "webp"]
  },
  "moderation": {
    "description": "内容审核强度",
    "type": "string",
    "default": "auto",
    "options": ["auto", "low"]
  },
  "output_compression": {
    "description": "输出压缩质量",
    "type": "int",
    "default": 0,
    "hint": "仅在输出格式不是 png 时生效；0 表示不发送该参数"
  },
  "n": {
    "description": "生成数量",
    "type": "int",
    "default": 1,
    "hint": "Responses API 模式下会并发多次请求"
  },
  "timeout": {
    "description": "请求超时时间（秒）",
    "type": "int",
    "default": 600
  },
  "response_format_b64_json": {
    "description": "请求返回 Base64 图片",
    "type": "bool",
    "default": true,
    "hint": "建议开启，可避免图片 URL 过期或访问失败"
  },
  "max_input_images": {
    "description": "最多输入参考图数量",
    "type": "int",
    "default": 4
  },
  "save_outputs": {
    "description": "保存生成结果",
    "type": "bool",
    "default": true
  },
  "render_text_as_image": {
    "description": "文本回复转图片",
    "type": "bool",
    "default": true,
    "hint": "开启后插件文本回复优先使用 image2 自包含 Markdown 卡片模板，不加载外部 JS/CDN；失败后直接使用插件内置 Pillow 兜底，仍失败则回退纯文本"
  },
  "text_image_width": {
    "description": "兜底文本图片宽度",
    "type": "int",
    "default": 1200,
    "hint": "仅用于插件内置兜底文转图，单位像素"
  },
  "text_image_font_size": {
    "description": "兜底文本图片字号",
    "type": "int",
    "default": 32,
    "hint": "仅用于插件内置兜底文转图"
  },
  "text_image_font_path": {
    "description": "兜底文本图片字体路径",
    "type": "string",
    "default": "",
    "hint": "仅用于插件内置兜底文转图；为空时自动选择系统中文字体"
  },
  "plan_enabled": {
    "description": "启用 Plan 模式",
    "type": "bool",
    "default": true
  },
  "plan_model": {
    "description": "Plan 模式 Responses 模型",
    "type": "string",
    "default": "gpt-5.4"
  },
  "plan_timeout": {
    "description": "Plan 会话超时时间（秒）",
    "type": "int",
    "default": 300,
    "hint": "用户空闲超时；模型思考和生图处理期间会自动延长"
  },
  "plan_max_rounds": {
    "description": "Plan 最大对话轮数",
    "type": "int",
    "default": 6
  },
  "plan_use_custom_api": {
    "description": "Plan 模式使用独立 API 配置",
    "type": "bool",
    "default": false,
    "hint": "开启后 plan_base_url 必须支持 /responses"
  },
  "plan_base_url": {
    "description": "Plan 独立 Responses API Base URL",
    "type": "string",
    "default": "",
    "hint": "仅在启用 plan_use_custom_api 时生效，不要以 /responses 结尾"
  },
  "plan_api_key": {
    "description": "Plan 独立 API Key",
    "type": "string",
    "default": "",
    "hint": "仅在启用 plan_use_custom_api 时生效"
  }
}
